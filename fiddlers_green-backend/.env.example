# Required — the Anthropic API key used by the /chat endpoint's AI
# Budtender. The /chat endpoint fails (returns a 502) without a valid key
# set here.
ANTHROPIC_API_KEY=

# Destination address that contact form submissions are sent to.
EMAIL_TO=

# The "From" address contact form emails are sent as.
SMTP_FROM=

# SMTP server hostname used to send contact form emails.
SMTP_HOST=

# SMTP server port. Use 587 for STARTTLS or 465 for SSL.
SMTP_PORT=

# SMTP account username used to authenticate outgoing mail.
SMTP_USER=

# SMTP account password used to authenticate outgoing mail.
SMTP_PASSWORD=

# The production frontend origin, added to the CORS allow-list alongside
# http://localhost:3000 (which is always allowed for local development).
# Set to the production domain (e.g. https://fiddlersgreen.ca). A missing
# or incorrect value will cause browser CORS errors in production.
FRONTEND_URL=

# Set to true in production to disable the FastAPI /docs and /redoc pages,
# hiding API structure from the public. Leave false (or unset) in local
# development so the interactive docs stay available.
DISABLE_DOCS=false
