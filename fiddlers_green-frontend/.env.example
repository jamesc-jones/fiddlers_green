# The full URL of the backend API (e.g. https://api.fiddlersgreen.ca in
# production). Leave this blank when building the Docker image for
# production — lib/api.ts falls back to the same host the page was served
# from at runtime, so an empty value there is intentional, not an oversight.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# The canonical public URL of this site, used in metadata (Open Graph,
# metadataBase, sitemap generation). Set to the production domain once one
# exists.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
